rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Projects collection - only authenticated users can read/write
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }
    
    // Contact submissions - anyone can submit, only authenticated users can read
    match /contactSubmissions/{submissionId} {
      allow create: if true; // Anyone can submit contact forms
      allow read: if request.auth != null; // Only authenticated users can read submissions
      allow update, delete: if request.auth != null; // Only authenticated users can manage submissions
    }
    
    // Admin users collection - only authenticated users can access
    match /admin/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Firebase Storage security rules
service firebase.storage {
  match /b/{bucket}/o {
    // Projects images - only authenticated users can upload
    match /projects/{imageId} {
      allow read: if true; // Anyone can view project images
      allow write: if request.auth != null; // Only authenticated users can upload
      allow delete: if request.auth != null; // Only authenticated users can delete
    }
    
    // Resume and portfolio files - only authenticated users can manage
    match /resume/{fileId} {
      allow read: if true; // Anyone can download resume
      allow write: if request.auth != null; // Only authenticated users can upload
      allow delete: if request.auth != null; // Only authenticated users can delete
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
